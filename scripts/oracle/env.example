# Copy to .oracle.env in the project root on the VM (chmod 600).
# GitHub fine-grained PAT or classic token with repo + workflow scopes.

GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=gengxianglong-star/us-industry-strength

# Optional: path to Netscape cookie file for Finviz (if Cloudflare blocks the VM IP)
# FINVIZ_COOKIE_FILE=/home/ubuntu/us-industry-strength/secrets/finviz_cookies.txt
